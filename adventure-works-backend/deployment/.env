# Application
APP_ENV=development
APP_PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adventureworks
DB_USER=your_db_user
DB_PASSWORD=your_db_password
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# SQL Server
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=AdventureWorks
MSSQL_USER=sa
MSSQL_SA_PASSWORD=Your_strong_password_123!

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=adventureworks
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=adventureworks
MONGO_USER=your_mongo_user
MONGO_PASSWORD=your_mongo_password
MONGO_URI=mongodb://your_mongo_user:your_mongo_password@localhost:27017/adventureworks

# API Gateway
API_GATEWAY_PORT=8080
API_GATEWAY_HOST=localhost
HUMAN_RESOURCE_API_PORT=8081

# Authentication
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=3600

# Monitoring
MONITORING_PORT=9090
